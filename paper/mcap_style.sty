% mcap_style.sty - MCAP paper style (adapted from NeurIPS 2025 template)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mcap_style}[2025/01/01 MCAP paper style (adapted from NeurIPS 2025)]

\newif\if@nipsfinal
\DeclareOption{final}{\@nipsfinaltrue}
\DeclareOption{preprint}{\@nipsfinalfalse}
\ProcessOptions\relax

% Page layout
\usepackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% Font and spacing
\renewcommand{\rmdefault}{ptm}
\renewcommand{\sfdefault}{phv}

\usepackage{natbib}
\setlength{\bibsep}{2pt plus 0.3ex}

% Title formatting
\renewcommand{\maketitle}{%
  \par
  \begingroup
  \renewcommand\thefootnote{\fnsymbol{footnote}}%
  \def\@makefnmark{\hbox to 0pt{$^{\@thefnmark}$\hss}}%
  \long\def\@makefntext##1{%
    \parindent 1em\noindent
    \hbox to 1.8em{\hss $\m@th ^{\@thefnmark}$}##1}%
  \thispagestyle{empty}
  \@maketitle
  \@thanks
  \endgroup
  \let\maketitle\relax \let\@maketitle\relax
  \gdef\@thanks{}\gdef\@author{}\gdef\@title{}\let\thanks\relax
}

\def\@maketitle{%
  \vbox to 0pt{}%
  \vskip -24pt
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.3in minus 0.1in
    {\large
      \lineskip .5em
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 0.3in minus 0.1in
  \end{center}%
}

% Abstract formatting
\renewenvironment{abstract}%
{\vskip 0.075in\centerline{\large\bfseries
Abstract}\vspace{0.5ex}\begin{quote}}{\par\end{quote}\vskip 1ex}

% Section formatting
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.0ex \@plus -0.5ex \@minus -0.2ex}%
  {1.5ex \@plus 0.3ex \@minus 0.2ex}%
  {\large\bfseries\sffamily}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-1.8ex \@plus -0.5ex \@minus -0.2ex}%
  {0.8ex \@plus 0.2ex}%
  {\normalsize\bfseries\sffamily}}
\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-1.5ex \@plus -0.5ex \@minus -0.2ex}%
  {0.5ex \@plus 0.2ex}%
  {\normalsize\bfseries\sffamily}}
\renewcommand\paragraph{\@startsection{paragraph}{4}{\z@}%
  {0.5ex \@plus 0.25ex \@minus 0.1ex}%
  {-1em}%
  {\normalsize\bfseries}}

% Footnote rule
\renewcommand\footnoterule{%
  \kern-3\p@
  \hrule width 2in
  \kern 2.6\p@}

\endinput
